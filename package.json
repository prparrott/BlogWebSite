{
  "name": "blog-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run db:seed && concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "tsx watch src/server/index.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "build": "tsc -b && vite build",
    "start": "tsx src/server/index.ts",
    "preview": "vite preview --host 127.0.0.1"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.9"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10"
  }
}
